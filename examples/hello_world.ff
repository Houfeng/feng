mod feng.examples;

@cdecl("libc")
extern fn puts(msg: string): int;

type User {
  let name: string;
  let age: i32;

  fn say(msg: string): void {
    puts(msg);
  }
}

/* main function */
fn main(args: string[]): void {
  let user = User {
    name: "Houfeng",
    age: 18
  };
  user.say("Hello World: " + user.name);
}