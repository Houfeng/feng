mod feng.examples;

spec X {
  let a: int;
  let b: string;
  fn foo(): void;
}

type User {
  let name: string;
  let age: int;
  fn say(msg: string): void {
    print(msg);
  }
}

@cdecl("libc")
extern fn print(msg: string): int;

/* main function */
fn main(args: string[]): void {
  let user = User {
    name: "Houfeng",
    age: 18
  };
  print("Hello World: " + user.name);
}