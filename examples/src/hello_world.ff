mod feng.examples.hello_world;

@cdecl("libc")
extern fn puts(msg: string): int;

type User {
  let name: string;
  let age: i32;

  /**
   * 测试
   */
  fn say(msg: string): void {
    puts(msg);
  }
}

fn hello_world_example(args: string[]): void {
  let user = User {
    name: "Houfeng",
    age: 18
  };
  user.say("Hello World: " + user.name);
}