{
  "name": "Feng",
  "scopeName": "source.feng",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#annotations"
    },
    {
      "include": "#functionDefinitions"
    },
    {
      "include": "#typeDefinitions"
    },
    {
      "include": "#specDefinitions"
    },
    {
      "include": "#fitDefinitions"
    },
    {
      "include": "#modulePaths"
    },
    {
      "include": "#aliases"
    },
    {
      "include": "#builtinTypes"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#booleans"
    },
    {
      "include": "#selfReference"
    },
    {
      "include": "#reservedWords"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#typeNames"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.feng",
          "match": "//.*$"
        },
        {
          "name": "comment.block.feng",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.feng",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.feng",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "entity.name.annotation.feng",
          "match": "@[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "functionDefinitions": {
      "patterns": [
        {
          "match": "\\b(fn)(\\s+)(~[A-Za-z_][A-Za-z0-9_]*|[A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.declaration.function.feng"
            },
            "3": {
              "name": "entity.name.function.feng"
            }
          }
        }
      ]
    },
    "typeDefinitions": {
      "patterns": [
        {
          "match": "\\b(type)(\\s+)([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.declaration.type.feng"
            },
            "3": {
              "name": "entity.name.type.feng"
            }
          }
        }
      ]
    },
    "specDefinitions": {
      "patterns": [
        {
          "match": "\\b(spec)(\\s+)([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.declaration.spec.feng"
            },
            "3": {
              "name": "entity.name.type.feng"
            }
          }
        }
      ]
    },
    "fitDefinitions": {
      "patterns": [
        {
          "match": "\\b(fit)(\\s+)([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.declaration.fit.feng"
            },
            "3": {
              "name": "entity.name.type.feng"
            }
          }
        }
      ]
    },
    "modulePaths": {
      "patterns": [
        {
          "match": "\\b(mod|use)(\\s+)([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)",
          "captures": {
            "1": {
              "name": "keyword.control.import.feng"
            },
            "3": {
              "name": "entity.name.namespace.feng"
            }
          }
        }
      ]
    },
    "aliases": {
      "patterns": [
        {
          "match": "\\b(as)(\\s+)([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.import.feng"
            },
            "3": {
              "name": "entity.name.namespace.alias.feng"
            }
          }
        }
      ]
    },
    "builtinTypes": {
      "patterns": [
        {
          "name": "support.type.builtin.feng",
          "match": "\\b(?:bool|string|int|long|byte|float|double|i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|void)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.feng",
          "match": "\\b0[xX][0-9A-Fa-f]+\\b"
        },
        {
          "name": "constant.numeric.binary.feng",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.octal.feng",
          "match": "\\b0[oO][0-7]+\\b"
        },
        {
          "name": "constant.numeric.feng",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.feng",
          "match": "\\b(?:true|false)\\b"
        }
      ]
    },
    "selfReference": {
      "patterns": [
        {
          "name": "variable.language.self.feng",
          "match": "\\bself\\b"
        }
      ]
    },
    "reservedWords": {
      "patterns": [
        {
          "name": "keyword.other.reserved.feng",
          "match": "\\b(?:class|struct|public|private|pub|pro|get|set|this|interface|static|enum|const|abstract|char|is)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.feng",
          "match": "\\b(?:extern|let|var|pu|pr|mod|use|as|if|else|while|for|break|continue|try|catch|finally|throw|return)\\b"
        }
      ]
    },
    "typeNames": {
      "patterns": [
        {
          "name": "support.type.user.feng",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.feng",
          "match": "->|&&|\\|\\||==|!=|<=|>=|=|\\+|-|\\*|/|%|<|>|!"
        },
        {
          "name": "punctuation.separator.feng",
          "match": "[,:;.]"
        },
        {
          "name": "punctuation.section.braces.begin.feng",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.braces.end.feng",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.parens.begin.feng",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.feng",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.brackets.begin.feng",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.feng",
          "match": "\\]"
        }
      ]
    }
  }
}