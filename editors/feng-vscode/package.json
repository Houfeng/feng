{
  "name": "feng-language",
  "displayName": "Feng Language",
  "description": "Syntax highlighting, document formatting, and LSP client integration for the Feng language.",
  "icon": "./icons/feng-logo.png",
  "version": "0.1.7",
  "publisher": "houfeng",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters"
  ],
  "scripts": {
    "test": "node ./test/formatter.test.js && node ./test/diagnostics.test.js && node ./test/icon.test.js && node ./test/syntax.test.js"
  },
  "activationEvents": [
    "onLanguage:feng",
    "onLanguage:feng-manifest"
  ],
  "main": "./extension.js",
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "keywords": [
    "feng",
    "language",
    "lang",
    "feng-lang",
    "feng-language",
    "formatter",
    "syntax",
    "ff",
    "fm",
    "fb",
    "ft"
  ],
  "contributes": {
    "languages": [
      {
        "id": "feng",
        "aliases": [
          "Feng",
          "feng"
        ],
        "extensions": [
          ".feng",
          ".ff"
        ],
        "icon": {
          "light": "./icons/feng-ff.svg",
          "dark": "./icons/feng-ff.svg"
        },
        "configuration": "./language-configuration.json"
      },
      {
        "id": "feng-manifest",
        "aliases": [
          "Feng Manifest",
          "feng-manifest"
        ],
        "extensions": [
          ".fm"
        ],
        "icon": {
          "light": "./icons/feng-fm.svg",
          "dark": "./icons/feng-fm.svg"
        },
        "configuration": "./manifest-language-configuration.json"
      },
      {
        "id": "feng-bundle",
        "aliases": [
          "Feng Bundle",
          "feng-bundle"
        ],
        "extensions": [
          ".fb"
        ],
        "icon": {
          "light": "./icons/feng-fb.svg",
          "dark": "./icons/feng-fb.svg"
        }
      },
      {
        "id": "feng-symbol-table",
        "aliases": [
          "Feng Symbol Table",
          "feng-symbol-table"
        ],
        "extensions": [
          ".ft"
        ],
        "icon": {
          "light": "./icons/feng-ft.svg",
          "dark": "./icons/feng-ft.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "feng",
        "scopeName": "source.feng",
        "path": "./syntaxes/feng.tmLanguage.json"
      },
      {
        "language": "feng-manifest",
        "scopeName": "source.fengmanifest",
        "path": "./syntaxes/feng-manifest.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Feng",
      "properties": {
        "feng.executablePath": {
          "type": "string",
          "default": "feng",
          "description": "Path to the Feng executable used to launch `feng lsp`. By default the extension runs `feng` from PATH. You can also use an absolute path or a path relative to the first workspace root (e.g. ./build/bin/feng)."
        }
      }
    }
  }
}