{
  "name": "feng-language",
  "displayName": "Feng Language",
  "description": "Syntax highlighting and document formatting support for the Feng language.",
  "icon": "./icons/feng-logo.png",
  "version": "0.1.2",
  "publisher": "houfeng",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters"
  ],
  "scripts": {
    "test": "node ./test/formatter.test.js && node ./test/diagnostics.test.js"
  },
  "main": "./extension.js",
  "keywords": [
    "feng",
    "language",
    "lang",
    "feng-lang",
    "feng-language",
    "formatter",
    "syntax",
    "ff",
    "fm",
    "fi"
  ],
  "contributes": {
    "languages": [
      {
        "id": "feng",
        "aliases": [
          "Feng",
          "feng"
        ],
        "extensions": [
          ".feng",
          ".ff",
          ".fm",
          ".fi"
        ],
        "icon": {
          "light": "./icons/feng-file.svg",
          "dark": "./icons/feng-file.svg"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "feng",
        "scopeName": "source.feng",
        "path": "./syntaxes/feng.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Feng",
      "properties": {
        "feng.executablePath": {
          "type": "string",
          "default": "feng",
          "description": "Path to the Feng executable. Use an absolute path or a path relative to the workspace root (e.g. ./build/bin/feng)."
        }
      }
    }
  }
}