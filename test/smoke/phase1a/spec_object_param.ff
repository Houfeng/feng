mod feng.smoke;

@cdecl("libc")
extern fn puts(msg: string): int;

spec Named {
    fn greet(): string;
}

type User: Named {
    let name: string;

    fn greet(): string {
        return self.name;
    }
}

fn announce(n: Named) {
    puts(n.greet());
}

fn main(args: string[]) {
    let u = User { name: "feng" };
    announce(u);
}
