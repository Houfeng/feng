mod feng.smoke;

@cdecl("libc")
extern fn puts(msg: string): int;

spec Named {
    fn greet(): string;
}

type User {
    let name: string;
}

fit User: Named {
    fn greet(): string {
        return "fit:" + self.name;
    }
}

fn announce(n: Named) {
    puts(n.greet());
}

fn main(args: string[]) {
    let u = User { name: "feng" };
    announce(u);
    let n: Named = User { name: "alice" };
    puts(n.greet());
}
