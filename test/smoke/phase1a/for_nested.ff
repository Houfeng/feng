mod feng.smoke;

@cdecl("libc")
extern fn puts(msg: string): int;

// Nested for: inner break must only exit the inner loop. Outer iteration
// continues past the inner break. Also verifies the init binding's scope
// is per-loop (no leakage of `j` into outer scope).
fn main(args: string[]) {
    for var i: i32 = 0; i < 2; i = i + 1 {
        for var j: i32 = 0; j < 5; j = j + 1 {
            if j == 1 {
                break;
            }
            puts("inner");
        }
        puts("outer");
    }
    puts("done");
}
