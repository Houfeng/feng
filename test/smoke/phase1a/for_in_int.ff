mod feng.smoke;

@cdecl("libc")
extern fn puts(msg: string): int;

fn main(args: string[]) {
    let nums: i32[] = [10, 20, 30];
    for let n in nums {
        if n == 10 {
            puts("ten");
        } else if n == 20 {
            puts("twenty");
        } else if n == 30 {
            puts("thirty");
        } else {
            puts("other");
        }
    }
    puts("done");
}
