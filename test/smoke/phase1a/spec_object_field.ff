mod feng.smoke;

@cdecl("libc") extern fn puts(msg: string): int;

spec Named {
    var name: string;
    fn greet(): string;
}

type User: Named {
    var name: string;
    fn greet(): string {
        return self.name;
    }
}

fn main(args: string[]) {
    let u = User { name: "feng" };
    let n: Named = u;
    puts(n.name);
    n.name = "tom";
    puts(n.name);
    puts(n.greet());
    puts(u.name);
}
