mod feng.smoke;

@cdecl("libc")
extern fn puts(msg: string): int;

// `for/in` continue must advance the iterator index. We skip the middle
// element via continue and verify the others still print in order.
fn main(args: string[]) {
    let nums: i32[] = [1, 2, 3];
    for let n in nums {
        if n == 2 {
            continue;
        }
        if n == 1 { puts("one"); }
        if n == 3 { puts("three"); }
    }
    puts("done");
}
