mod feng.smoke;

@cdecl("libc")
extern fn puts(msg: string): int;

// Exercises codegen for user-defined finalizers (`fn ~T()`):
// the runtime invokes the finalizer through descriptor.finalizer when
// ARC reclaims the instance at end of scope.
type Greeter {
    let label: string;

    fn ~Greeter() {
        puts(self.label);
    }
}

fn main(args: string[]) {
    let g = Greeter { label: "fin" };
    puts("built");
}
