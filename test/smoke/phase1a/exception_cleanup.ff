mod feng.smoke;

@cdecl("libc")
extern fn puts(msg: string): int;

// A function that allocates a managed local (writable array) and then throws.
// The cleanup chain must release `tmp` before the longjmp transfers control.
fn build_and_throw() {
    let tmp: i32[]! = [1, 2, 3]!;
    throw "boom-from-fn";
}

// A function that allocates a managed local and returns normally.
fn build_and_return() {
    let tmp: i32[]! = [9, 8, 7]!;
    puts("normal-return");
}

fn main(args: string[]) {
    // Caller also has a managed local; it must survive the throw and be
    // released by its own scope on normal exit.
    let outer: i32[]! = [10, 20, 30]!;

    try {
        // Managed local declared inside the try, before the throw, must be
        // released by the runtime cleanup walk on the longjmp path.
        let in_try: i32[]! = [100, 200, 300]!;
        build_and_throw();
        puts("unreachable");
    } catch {
        puts("caught");
    }

    build_and_return();
    puts("after");
}
